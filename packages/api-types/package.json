{
  "name": "@droptracker/api-types",
  "version": "0.1.0",
  "private": true,
  "description": "Web API v1 contract: OpenAPI-generated TS types + shared Zod schemas.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi": "./openapi.json",
    "./generated": "./src/generated/openapi.ts"
  },
  "scripts": {
    "gen": "openapi-typescript ./openapi.json -o ./src/generated/openapi.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --test"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@droptracker/config": "workspace:*",
    "eslint": "^9.18.0",
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.7.3"
  }
}
