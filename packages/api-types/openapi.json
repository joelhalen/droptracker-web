{
  "openapi": "3.1.0",
  "info": {
    "title": "DropTracker Web API",
    "version": "1.0.0",
    "description": "Versioned, browser-oriented JSON API consumed by the Next.js BFF. Separate from the RuneLite intake API. See FRONTEND_PLAN.md §6."
  },
  "servers": [{ "url": "/api/v1" }],
  "tags": [
    { "name": "leaderboards" },
    { "name": "players" },
    { "name": "groups" },
    { "name": "announcements" },
    { "name": "me" },
    { "name": "admin" }
  ],
  "paths": {
    "/leaderboards/players": {
      "get": {
        "tags": ["leaderboards"],
        "operationId": "getPlayerLeaderboard",
        "summary": "Player loot leaderboard",
        "parameters": [
          { "$ref": "#/components/parameters/Period" },
          { "$ref": "#/components/parameters/Scope" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": {
          "200": {
            "description": "A page of leaderboard entries.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LeaderboardPage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/leaderboards/groups": {
      "get": {
        "tags": ["leaderboards"],
        "operationId": "getGroupLeaderboard",
        "summary": "Group loot leaderboard",
        "parameters": [
          { "$ref": "#/components/parameters/Period" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": {
          "200": {
            "description": "A page of group leaderboard entries.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LeaderboardPage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/players/{playerId}": {
      "get": {
        "tags": ["players"],
        "operationId": "getPlayer",
        "summary": "Player profile",
        "parameters": [{ "$ref": "#/components/parameters/PlayerId" }],
        "responses": {
          "200": {
            "description": "Player profile payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlayerProfile" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/players/search": {
      "get": {
        "tags": ["players"],
        "operationId": "searchPlayers",
        "summary": "Search players by name",
        "parameters": [{ "$ref": "#/components/parameters/Query" }],
        "responses": {
          "200": {
            "description": "Matching players.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PlayerSummary" }
                }
              }
            }
          }
        }
      }
    },
    "/groups/{groupId}": {
      "get": {
        "tags": ["groups"],
        "operationId": "getGroup",
        "summary": "Group profile",
        "parameters": [{ "$ref": "#/components/parameters/GroupId" }],
        "responses": {
          "200": {
            "description": "Group profile payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GroupProfile" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/announcements": {
      "get": {
        "tags": ["announcements"],
        "operationId": "listAnnouncements",
        "summary": "List announcements",
        "parameters": [
          { "$ref": "#/components/parameters/Scope" },
          { "$ref": "#/components/parameters/Cursor" }
        ],
        "responses": {
          "200": {
            "description": "A page of announcements.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnnouncementPage" }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["me"],
        "operationId": "getMe",
        "summary": "Current session: user, linked players, group roles",
        "security": [{ "session": [] }],
        "responses": {
          "200": {
            "description": "Authenticated user payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Me" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/overview": {
      "get": {
        "tags": ["admin"],
        "operationId": "getAdminOverview",
        "summary": "Superadmin site overview KPIs",
        "security": [{ "session": [] }],
        "responses": {
          "200": {
            "description": "Dashboard KPI tiles.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminOverview" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/groups/{groupId}/subscription/grant": {
      "post": {
        "tags": ["admin"],
        "operationId": "adminGrantSubscription",
        "summary": "Grant a comped (manual) subscription to a group",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/GroupId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminSubscriptionGrantInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The upserted subscription.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GroupSubscription" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/groups/{groupId}/subscription/revoke": {
      "post": {
        "tags": ["admin"],
        "operationId": "adminRevokeSubscription",
        "summary": "Revoke a group's subscription (set canceled)",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/GroupId" }],
        "responses": {
          "200": {
            "description": "The updated subscription.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GroupSubscription" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/data/{entity}": {
      "get": {
        "tags": ["admin"],
        "operationId": "adminDataList",
        "summary": "List rows for a whitelisted entity",
        "security": [{ "session": [] }],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Limit" },
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A page of rows.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminDataListResponse" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/data/{entity}/{id}": {
      "get": {
        "tags": ["admin"],
        "operationId": "adminDataGet",
        "summary": "Get a single record",
        "security": [{ "session": [] }],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "The record.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminDataRecordResponse" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "tags": ["admin"],
        "operationId": "adminDataPatch",
        "summary": "Update allowlisted editable columns on a record",
        "security": [{ "session": [] }],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminDataPatchInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated record.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminDataRecordResponse" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/logs": {
      "get": {
        "tags": ["admin"],
        "operationId": "adminLogs",
        "summary": "Tail the application logs table",
        "security": [{ "session": [] }],
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 200 }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent log entries and known sources.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminLogsResponse" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/admin/groups/{groupId}/overview": {
      "get": {
        "tags": ["admin"],
        "operationId": "adminGroupOverview",
        "summary": "Superadmin per-group staff overview",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/GroupId" }],
        "responses": {
          "200": {
            "description": "Group staff overview.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminGroupOverview" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "dt_session"
      }
    },
    "parameters": {
      "Period": {
        "name": "period",
        "in": "query",
        "description": "Time partition: YYYYMM (monthly), YYYYWW (weekly), YYYYMMDD (daily) or 'all'.",
        "schema": { "type": "string", "default": "all" }
      },
      "Scope": {
        "name": "scope",
        "in": "query",
        "description": "global | group:{id} | npc:{id} | player:{id}",
        "schema": { "type": "string", "default": "global" }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
      },
      "Cursor": {
        "name": "cursor",
        "in": "query",
        "schema": { "type": "string" }
      },
      "Query": {
        "name": "q",
        "in": "query",
        "required": true,
        "schema": { "type": "string", "minLength": 1 }
      },
      "PlayerId": {
        "name": "playerId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "GroupId": {
        "name": "groupId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      }
    },
    "responses": {
      "Error": {
        "description": "RFC-7807 problem details.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      }
    },
    "schemas": {
      "Problem": {
        "type": "object",
        "description": "RFC-7807 error envelope.",
        "required": ["title", "status"],
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" }
        }
      },
      "Money": {
        "type": "object",
        "description": "GP value: raw integer plus a preformatted display string.",
        "required": ["value", "value_formatted"],
        "properties": {
          "value": { "type": "integer", "format": "int64" },
          "value_formatted": { "type": "string", "examples": ["123.5M"] }
        }
      },
      "PageMeta": {
        "type": "object",
        "required": ["page", "limit", "total"],
        "properties": {
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "LeaderboardEntry": {
        "type": "object",
        "required": ["rank", "id", "name", "loot"],
        "properties": {
          "rank": { "type": "integer" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "loot": { "$ref": "#/components/schemas/Money" },
          "delta": { "type": "integer", "description": "Recent change in GP (for live deltas)." }
        }
      },
      "LeaderboardPage": {
        "type": "object",
        "required": ["period", "scope", "entries", "meta"],
        "properties": {
          "period": { "type": "string" },
          "scope": { "type": "string" },
          "entries": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LeaderboardEntry" }
          },
          "meta": { "$ref": "#/components/schemas/PageMeta" }
        }
      },
      "PlayerSummary": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "global_rank": { "type": "integer" },
          "total_loot": { "$ref": "#/components/schemas/Money" }
        }
      },
      "Submission": {
        "type": "object",
        "required": ["id", "type", "label", "ts"],
        "properties": {
          "id": { "type": "integer" },
          "type": {
            "type": "string",
            "enum": ["drop", "clog", "pb", "ca", "pet", "level", "quest"]
          },
          "label": { "type": "string" },
          "value": { "$ref": "#/components/schemas/Money" },
          "image_url": { "type": "string" },
          "ts": { "type": "integer", "description": "Unix seconds." }
        }
      },
      "GroupMembership": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "PlayerProfile": {
        "allOf": [
          { "$ref": "#/components/schemas/PlayerSummary" },
          {
            "type": "object",
            "properties": {
              "points": { "type": "integer" },
              "top_npc": { "type": "string" },
              "groups": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/GroupMembership" }
              },
              "recent_submissions": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Submission" }
              }
            }
          }
        ]
      },
      "GroupProfile": {
        "type": "object",
        "required": ["id", "name", "member_count"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "member_count": { "type": "integer" },
          "global_rank": { "type": "integer" },
          "monthly_loot": { "$ref": "#/components/schemas/Money" },
          "discord_url": { "type": "string" },
          "top_player": { "$ref": "#/components/schemas/PlayerSummary" },
          "recent_submissions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Submission" }
          }
        }
      },
      "Announcement": {
        "type": "object",
        "required": ["id", "scope_type", "title", "body_md", "published_at"],
        "properties": {
          "id": { "type": "integer" },
          "scope_type": { "type": "string", "enum": ["global", "group"] },
          "group_id": { "type": "integer", "nullable": true },
          "title": { "type": "string" },
          "body_md": { "type": "string" },
          "cover_image_url": { "type": "string", "nullable": true },
          "pinned": { "type": "boolean" },
          "author_name": { "type": "string" },
          "published_at": { "type": "integer", "description": "Unix seconds." }
        }
      },
      "AnnouncementPage": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Announcement" }
          },
          "next_cursor": { "type": "string", "nullable": true }
        }
      },
      "Me": {
        "type": "object",
        "required": ["user_id", "discord_id", "players", "groups"],
        "properties": {
          "user_id": { "type": "integer" },
          "discord_id": { "type": "string" },
          "display_name": { "type": "string" },
          "avatar_url": { "type": "string", "nullable": true },
          "players": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlayerSummary" }
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "role"],
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" },
                "role": {
                  "type": "string",
                  "enum": ["owner", "admin", "member"]
                }
              }
            }
          }
        }
      },
      "GroupSubscription": {
        "type": "object",
        "required": ["group_id", "tier_key", "status", "provider", "current_period_end", "cancel_at_period_end"],
        "properties": {
          "group_id": { "type": "integer" },
          "tier_key": { "type": "string", "nullable": true },
          "status": {
            "type": "string",
            "enum": ["none", "active", "trialing", "past_due", "canceled", "expired"]
          },
          "provider": {
            "type": "string",
            "enum": ["patreon", "stripe", "manual"],
            "nullable": true
          },
          "current_period_end": { "type": "integer", "nullable": true, "description": "Unix seconds." },
          "cancel_at_period_end": { "type": "boolean" }
        }
      },
      "AdminOverviewStat": {
        "type": "object",
        "required": ["key", "label", "value"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "value": { "type": "integer" },
          "hint": { "type": "string" }
        }
      },
      "AdminOverview": {
        "type": "object",
        "required": ["stats", "generated_at"],
        "properties": {
          "stats": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AdminOverviewStat" }
          },
          "generated_at": { "type": "integer", "description": "Unix seconds." }
        }
      },
      "AdminSubscriptionGrantInput": {
        "type": "object",
        "required": ["tier_key", "days"],
        "properties": {
          "tier_key": { "type": "string" },
          "days": { "type": "integer", "minimum": 1, "maximum": 3650 }
        }
      },
      "AdminDataRow": {
        "type": "object",
        "additionalProperties": {
          "nullable": true,
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      },
      "AdminDataListResponse": {
        "type": "object",
        "required": ["entity", "columns", "rows", "editable", "meta"],
        "properties": {
          "entity": { "type": "string" },
          "columns": { "type": "array", "items": { "type": "string" } },
          "rows": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AdminDataRow" }
          },
          "editable": { "type": "array", "items": { "type": "string" } },
          "meta": { "$ref": "#/components/schemas/PageMeta" }
        }
      },
      "AdminDataRecordResponse": {
        "type": "object",
        "required": ["entity", "id", "record", "editable"],
        "properties": {
          "entity": { "type": "string" },
          "id": { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
          "record": { "$ref": "#/components/schemas/AdminDataRow" },
          "editable": { "type": "array", "items": { "type": "string" } }
        }
      },
      "AdminDataPatchInput": {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "fields": { "$ref": "#/components/schemas/AdminDataRow" }
        }
      },
      "AdminLogEntry": {
        "type": "object",
        "required": ["ts", "level", "source", "message"],
        "properties": {
          "ts": { "type": "integer", "description": "Unix seconds." },
          "level": { "type": "string" },
          "source": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "AdminLogsResponse": {
        "type": "object",
        "required": ["entries", "sources"],
        "properties": {
          "entries": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AdminLogEntry" }
          },
          "sources": { "type": "array", "items": { "type": "string" } }
        }
      },
      "AdminGroupOverview": {
        "type": "object",
        "required": ["group", "subscription", "config_summary", "activity_7d", "last_submission_ts", "warnings"],
        "properties": {
          "group": {
            "type": "object",
            "required": ["id", "name", "member_count", "guild_id", "wom_id"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "member_count": { "type": "integer" },
              "guild_id": { "type": "string", "nullable": true },
              "wom_id": { "type": "integer", "nullable": true }
            }
          },
          "subscription": { "$ref": "#/components/schemas/GroupSubscription" },
          "config_summary": {
            "type": "object",
            "additionalProperties": { "type": "string", "nullable": true }
          },
          "activity_7d": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["date", "submissions"],
              "properties": {
                "date": { "type": "string" },
                "submissions": { "type": "integer" }
              }
            }
          },
          "last_submission_ts": { "type": "integer", "nullable": true },
          "warnings": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
