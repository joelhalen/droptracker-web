{
  "openapi": "3.1.0",
  "info": {
    "title": "DropTracker Web API",
    "version": "1.0.0",
    "description": "Versioned, browser-oriented JSON API consumed by the Next.js BFF. Separate from the RuneLite intake API. See FRONTEND_PLAN.md §6."
  },
  "servers": [{ "url": "/api/v1" }],
  "tags": [
    { "name": "leaderboards" },
    { "name": "players" },
    { "name": "groups" },
    { "name": "announcements" },
    { "name": "me" }
  ],
  "paths": {
    "/events": {
      "get": {
        "tags": ["events"],
        "operationId": "listEvents",
        "summary": "List events (drafts visible to event admins only)",
        "parameters": [
          {
            "name": "groupId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["draft", "active", "past"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Events visible to the requester.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EventSummary" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["events"],
        "operationId": "createEvent",
        "summary": "Create a draft event (group admin; superadmin for global)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EventInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Id of the created draft event.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id"],
                  "properties": { "id": { "type": "integer" } }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/events/{eventId}": {
      "get": {
        "tags": ["events"],
        "operationId": "getEvent",
        "summary": "Event detail (tasks, teams, progress, bingo board)",
        "parameters": [{ "$ref": "#/components/parameters/EventId" }],
        "responses": {
          "200": {
            "description": "Event detail payload. join_code appears only for event admins.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EventDetail" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "tags": ["events"],
        "operationId": "updateEvent",
        "summary": "Update event settings (event admin)",
        "parameters": [{ "$ref": "#/components/parameters/EventId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EventPatch" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The refreshed event detail.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EventDetail" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/leaderboards/players": {
      "get": {
        "tags": ["leaderboards"],
        "operationId": "getPlayerLeaderboard",
        "summary": "Player loot leaderboard",
        "parameters": [
          { "$ref": "#/components/parameters/Period" },
          { "$ref": "#/components/parameters/Scope" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": {
          "200": {
            "description": "A page of leaderboard entries.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LeaderboardPage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/leaderboards/groups": {
      "get": {
        "tags": ["leaderboards"],
        "operationId": "getGroupLeaderboard",
        "summary": "Group loot leaderboard",
        "parameters": [
          { "$ref": "#/components/parameters/Period" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": {
          "200": {
            "description": "A page of group leaderboard entries.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LeaderboardPage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/players/{playerId}": {
      "get": {
        "tags": ["players"],
        "operationId": "getPlayer",
        "summary": "Player profile",
        "parameters": [{ "$ref": "#/components/parameters/PlayerId" }],
        "responses": {
          "200": {
            "description": "Player profile payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlayerProfile" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/players/{playerId}/loot": {
      "get": {
        "tags": ["players"],
        "operationId": "getPlayerLoot",
        "summary": "Player loot tracker (drops grouped by NPC for one month)",
        "parameters": [
          { "$ref": "#/components/parameters/PlayerId" },
          {
            "name": "partition",
            "in": "query",
            "required": false,
            "description": "YYYYMM month to show; defaults to the current month.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Loot tracker payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlayerLootTracker" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/players/search": {
      "get": {
        "tags": ["players"],
        "operationId": "searchPlayers",
        "summary": "Search players by name",
        "parameters": [{ "$ref": "#/components/parameters/Query" }],
        "responses": {
          "200": {
            "description": "Matching players.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PlayerSummary" }
                }
              }
            }
          }
        }
      }
    },
    "/groups/{groupId}": {
      "get": {
        "tags": ["groups"],
        "operationId": "getGroup",
        "summary": "Group profile",
        "parameters": [{ "$ref": "#/components/parameters/GroupId" }],
        "responses": {
          "200": {
            "description": "Group profile payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GroupProfile" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/announcements": {
      "get": {
        "tags": ["announcements"],
        "operationId": "listAnnouncements",
        "summary": "List announcements",
        "parameters": [
          { "$ref": "#/components/parameters/Scope" },
          { "$ref": "#/components/parameters/Cursor" }
        ],
        "responses": {
          "200": {
            "description": "A page of announcements.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnnouncementPage" }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["me"],
        "operationId": "getMe",
        "summary": "Current session: user, linked players, group roles",
        "security": [{ "session": [] }],
        "responses": {
          "200": {
            "description": "Authenticated user payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Me" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "dt_session"
      }
    },
    "parameters": {
      "Period": {
        "name": "period",
        "in": "query",
        "description": "Time partition: YYYYMM (monthly), YYYYWW (weekly), YYYYMMDD (daily) or 'all'.",
        "schema": { "type": "string", "default": "all" }
      },
      "Scope": {
        "name": "scope",
        "in": "query",
        "description": "global | group:{id} | npc:{id} | player:{id}",
        "schema": { "type": "string", "default": "global" }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
      },
      "Cursor": {
        "name": "cursor",
        "in": "query",
        "schema": { "type": "string" }
      },
      "Query": {
        "name": "q",
        "in": "query",
        "required": true,
        "schema": { "type": "string", "minLength": 1 }
      },
      "PlayerId": {
        "name": "playerId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "GroupId": {
        "name": "groupId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "EventId": {
        "name": "eventId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      }
    },
    "responses": {
      "Error": {
        "description": "RFC-7807 problem details.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      }
    },
    "schemas": {
      "EventSummary": {
        "type": "object",
        "required": ["id", "group_id", "name", "status", "starts_at", "ends_at", "has_bingo", "formation_mode", "requires_confirmation", "submission_policy", "board_size", "bonus_line_points", "bonus_blackout_points"],
        "properties": {
          "id": { "type": "integer" },
          "group_id": { "type": "integer", "nullable": true, "description": "null => global event." },
          "name": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "status": { "type": "string", "enum": ["draft", "active", "past"] },
          "starts_at": { "type": "integer", "nullable": true, "description": "Unix seconds." },
          "ends_at": { "type": "integer", "nullable": true, "description": "Unix seconds." },
          "has_bingo": { "type": "boolean", "default": false },
          "formation_mode": { "type": "string", "enum": ["self_join", "auto_assign", "admin_assign"], "default": "admin_assign" },
          "requires_confirmation": { "type": "boolean", "default": false, "description": "Event-level force: all completions queue for admin review." },
          "submission_policy": { "type": "string", "enum": ["all", "confirm_non_api", "api_only"], "default": "all", "description": "Which submissions the completion engine accepts: 'all' \u2014 everything counts; 'confirm_non_api' \u2014 non-plugin submissions land as pending completions needing admin confirmation; 'api_only' \u2014 submissions without the plugin API flag are ignored." },
          "board_size": { "type": "integer", "default": 5 },
          "bonus_line_points": { "type": "integer", "default": 0 },
          "bonus_blackout_points": { "type": "integer", "default": 0 },
          "activated_at": { "type": "integer", "nullable": true },
          "ended_at": { "type": "integer", "nullable": true }
        }
      },
      "EventTask": {
        "type": "object",
        "required": ["id", "type", "label", "points", "requires_confirmation"],
        "properties": {
          "id": { "type": "integer" },
          "type": { "type": "string", "enum": ["item_collection", "kc_target", "xp_target", "ehp_target", "ehb_target", "pb_target", "skill_target", "loot_value", "custom"] },
          "label": { "type": "string" },
          "target": { "type": "string", "nullable": true },
          "target_value": { "type": "integer", "nullable": true },
          "points": { "type": "integer", "default": 0 },
          "requires_confirmation": { "type": "boolean", "default": false },
          "config": { "type": "string", "nullable": true, "description": "JSON string: any_of/assembly/point_collection item lists etc." }
        }
      },
      "EventMember": {
        "type": "object",
        "required": ["player_id", "player_name", "joined_at"],
        "properties": {
          "player_id": { "type": "integer" },
          "player_name": { "type": "string" },
          "joined_at": { "type": "integer", "nullable": true, "description": "Unix seconds; the credit cutoff." }
        }
      },
      "EventTeam": {
        "type": "object",
        "required": ["id", "name", "score", "member_count"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "score": { "type": "integer", "default": 0 },
          "member_count": { "type": "integer", "default": 0 },
          "members": { "type": "array", "items": { "$ref": "#/components/schemas/EventMember" } }
        }
      },
      "EventProgress": {
        "type": "object",
        "required": ["task_id", "team_id", "progress", "completed"],
        "properties": {
          "task_id": { "type": "integer" },
          "team_id": { "type": "integer" },
          "progress": { "type": "integer", "default": 0 },
          "completed": { "type": "boolean", "default": false },
          "completed_at": { "type": "integer", "nullable": true }
        }
      },
      "BingoCellCompletion": {
        "type": "object",
        "properties": {
          "team_id": { "type": "integer", "nullable": true },
          "team_name": { "type": "string", "nullable": true },
          "player_id": { "type": "integer", "nullable": true },
          "player_name": { "type": "string", "nullable": true },
          "completed_at": { "type": "integer", "nullable": true }
        }
      },
      "BingoCell": {
        "type": "object",
        "required": ["index", "label"],
        "properties": {
          "index": { "type": "integer" },
          "label": { "type": "string" },
          "task_id": { "type": "integer", "nullable": true },
          "completed_by": { "type": "array", "items": { "type": "string" } },
          "completions": { "type": "array", "items": { "$ref": "#/components/schemas/BingoCellCompletion" } }
        }
      },
      "BingoBoard": {
        "type": "object",
        "required": ["size", "cells"],
        "properties": {
          "size": { "type": "integer", "description": "Board is size \u00d7 size." },
          "cells": { "type": "array", "items": { "$ref": "#/components/schemas/BingoCell" } }
        }
      },
      "EventViewer": {
        "type": "object",
        "properties": {
          "player_ids_on_event": { "type": "array", "items": { "type": "integer" } },
          "team_id": { "type": "integer", "nullable": true }
        }
      },
      "EventDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/EventSummary" },
          {
            "type": "object",
            "required": ["join_requires_code"],
            "properties": {
              "tasks": { "type": "array", "items": { "$ref": "#/components/schemas/EventTask" } },
              "teams": { "type": "array", "items": { "$ref": "#/components/schemas/EventTeam" } },
              "progress": { "type": "array", "items": { "$ref": "#/components/schemas/EventProgress" } },
              "bingo": { "$ref": "#/components/schemas/BingoBoard" },
              "viewer": { "$ref": "#/components/schemas/EventViewer" },
              "join_requires_code": { "type": "boolean", "default": false },
              "join_code": { "type": "string", "nullable": true, "description": "Admin-only: present only when the requester administers the event." },
              "discord_guild_id": { "type": "string", "nullable": true }
            }
          }
        ]
      },
      "EventInput": {
        "type": "object",
        "required": ["group_id", "name"],
        "properties": {
          "group_id": { "type": "integer", "nullable": true, "description": "null => global event (superadmin only)." },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "starts_at": { "type": "integer", "nullable": true },
          "ends_at": { "type": "integer", "nullable": true },
          "formation_mode": { "type": "string", "enum": ["self_join", "auto_assign", "admin_assign"] },
          "requires_confirmation": { "type": "boolean" },
          "submission_policy": { "type": "string", "enum": ["all", "confirm_non_api", "api_only"], "description": "422 on any other value." },
          "join_code": { "type": "string", "nullable": true },
          "board_size": { "type": "integer" },
          "bonus_line_points": { "type": "integer" },
          "bonus_blackout_points": { "type": "integer" }
        }
      },
      "EventPatch": {
        "type": "object",
        "description": "Any subset of EventInput fields except group_id.",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "starts_at": { "type": "integer", "nullable": true },
          "ends_at": { "type": "integer", "nullable": true },
          "formation_mode": { "type": "string", "enum": ["self_join", "auto_assign", "admin_assign"] },
          "requires_confirmation": { "type": "boolean" },
          "submission_policy": { "type": "string", "enum": ["all", "confirm_non_api", "api_only"], "description": "422 on any other value." },
          "join_code": { "type": "string", "nullable": true },
          "board_size": { "type": "integer" },
          "bonus_line_points": { "type": "integer" },
          "bonus_blackout_points": { "type": "integer" }
        }
      },
      "Problem": {
        "type": "object",
        "description": "RFC-7807 error envelope.",
        "required": ["title", "status"],
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" }
        }
      },
      "Money": {
        "type": "object",
        "description": "GP value: raw integer plus a preformatted display string.",
        "required": ["value", "value_formatted"],
        "properties": {
          "value": { "type": "integer", "format": "int64" },
          "value_formatted": { "type": "string", "examples": ["123.5M"] }
        }
      },
      "PageMeta": {
        "type": "object",
        "required": ["page", "limit", "total"],
        "properties": {
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "GroupFlair": {
        "type": "object",
        "description": "Cosmetic subscription-tier display style for a group's name. Present only for groups with an active/trialing subscription to a tier whose flair is not 'none'.",
        "required": ["tier_key", "tier_name", "style"],
        "properties": {
          "tier_key": { "type": "string" },
          "tier_name": { "type": "string" },
          "style": {
            "type": "string",
            "enum": ["none", "bronze", "gold", "amethyst", "dragon"]
          }
        }
      },
      "LeaderboardEntry": {
        "type": "object",
        "required": ["rank", "id", "name", "loot"],
        "properties": {
          "rank": { "type": "integer" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "loot": { "$ref": "#/components/schemas/Money" },
          "delta": { "type": "integer", "description": "Recent change in GP (for live deltas)." },
          "flair": { "$ref": "#/components/schemas/GroupFlair" }
        }
      },
      "LeaderboardPage": {
        "type": "object",
        "required": ["period", "scope", "entries", "meta"],
        "properties": {
          "period": { "type": "string" },
          "scope": { "type": "string" },
          "entries": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LeaderboardEntry" }
          },
          "meta": { "$ref": "#/components/schemas/PageMeta" }
        }
      },
      "PlayerSummary": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "global_rank": { "type": "integer" },
          "total_loot": { "$ref": "#/components/schemas/Money" }
        }
      },
      "Submission": {
        "type": "object",
        "required": ["id", "type", "label", "ts"],
        "properties": {
          "id": { "type": "integer" },
          "type": {
            "type": "string",
            "enum": ["drop", "clog", "pb", "ca", "pet", "level", "quest"]
          },
          "label": { "type": "string" },
          "value": { "$ref": "#/components/schemas/Money" },
          "image_url": { "type": "string" },
          "ts": { "type": "integer", "description": "Unix seconds." }
        }
      },
      "GroupMembership": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "flair": { "$ref": "#/components/schemas/GroupFlair" }
        }
      },
      "TopBoss": {
        "type": "object",
        "required": ["npc_id", "name", "loot", "drops"],
        "properties": {
          "npc_id": { "type": "integer" },
          "name": { "type": "string" },
          "loot": { "$ref": "#/components/schemas/Money" },
          "drops": { "type": "integer" }
        }
      },
      "LootTrackerItem": {
        "type": "object",
        "required": ["item_id", "name", "quantity", "loot"],
        "properties": {
          "item_id": { "type": "integer" },
          "name": { "type": "string" },
          "quantity": { "type": "integer", "format": "int64" },
          "loot": { "$ref": "#/components/schemas/Money" }
        }
      },
      "LootTrackerNpc": {
        "type": "object",
        "required": ["npc_id", "name", "kills", "loot", "items"],
        "properties": {
          "npc_id": { "type": "integer" },
          "name": { "type": "string" },
          "kills": {
            "type": "integer",
            "description": "Distinct drop events (multi-item kills counted once)."
          },
          "loot": { "$ref": "#/components/schemas/Money" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LootTrackerItem" }
          }
        }
      },
      "PlayerLootTracker": {
        "type": "object",
        "required": ["player_id", "partition", "earliest_partition", "npcs"],
        "properties": {
          "player_id": { "type": "integer" },
          "partition": { "type": "integer", "description": "YYYYMM month shown." },
          "earliest_partition": {
            "type": "integer",
            "description": "First YYYYMM with tracked drops (month-picker lower bound)."
          },
          "npcs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LootTrackerNpc" }
          }
        }
      },
      "GroupTopPlayer": {
        "type": "object",
        "required": ["rank", "id", "name", "loot"],
        "properties": {
          "rank": { "type": "integer" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "loot": { "$ref": "#/components/schemas/Money" }
        }
      },
      "GroupRecord": {
        "type": "object",
        "required": ["npc_id", "boss", "time_ms", "time_display", "team_size", "holder", "date_ts"],
        "properties": {
          "npc_id": { "type": "integer" },
          "boss": { "type": "string" },
          "time_ms": { "type": "integer" },
          "time_display": { "type": "string" },
          "team_size": { "type": "string" },
          "holder": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          },
          "date_ts": { "type": "integer", "description": "Unix seconds the record was set." }
        }
      },
      "PersonalBestSummary": {
        "type": "object",
        "required": ["npc_id", "boss", "time_ms", "time_display", "team_size", "date_ts"],
        "properties": {
          "npc_id": { "type": "integer" },
          "boss": { "type": "string" },
          "time_ms": { "type": "integer" },
          "time_display": { "type": "string" },
          "team_size": { "type": "string" },
          "date_ts": { "type": "integer" }
        }
      },
      "PlayerProfile": {
        "allOf": [
          { "$ref": "#/components/schemas/PlayerSummary" },
          {
            "type": "object",
            "properties": {
              "points": { "type": "integer" },
              "top_npc": { "type": "string" },
              "previous_month_loot": { "$ref": "#/components/schemas/Money" },
              "ranked_players": {
                "type": "integer",
                "description": "Total players on the global board, for percentile context."
              },
              "top_bosses": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/TopBoss" }
              },
              "personal_bests": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/PersonalBestSummary" }
              },
              "groups": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/GroupMembership" }
              },
              "recent_submissions": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Submission" }
              }
            }
          }
        ]
      },
      "GroupProfile": {
        "type": "object",
        "required": ["id", "name", "member_count"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "member_count": { "type": "integer" },
          "global_rank": { "type": "integer" },
          "monthly_loot": { "$ref": "#/components/schemas/Money" },
          "discord_url": { "type": "string" },
          "top_player": { "$ref": "#/components/schemas/PlayerSummary" },
          "top_players": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GroupTopPlayer" }
          },
          "top_bosses": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TopBoss" }
          },
          "records": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GroupRecord" }
          },
          "recent_submissions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Submission" }
          },
          "flair": { "$ref": "#/components/schemas/GroupFlair" }
        }
      },
      "Announcement": {
        "type": "object",
        "required": ["id", "scope_type", "title", "body_md", "published_at"],
        "properties": {
          "id": { "type": "integer" },
          "scope_type": { "type": "string", "enum": ["global", "group"] },
          "group_id": { "type": "integer", "nullable": true },
          "title": { "type": "string" },
          "body_md": { "type": "string" },
          "cover_image_url": { "type": "string", "nullable": true },
          "pinned": { "type": "boolean" },
          "author_name": { "type": "string" },
          "published_at": { "type": "integer", "description": "Unix seconds." }
        }
      },
      "AnnouncementPage": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Announcement" }
          },
          "next_cursor": { "type": "string", "nullable": true }
        }
      },
      "Me": {
        "type": "object",
        "required": ["user_id", "discord_id", "players", "groups"],
        "properties": {
          "user_id": { "type": "integer" },
          "discord_id": { "type": "string" },
          "display_name": { "type": "string" },
          "avatar_url": { "type": "string", "nullable": true },
          "players": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlayerSummary" }
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "role"],
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" },
                "role": {
                  "type": "string",
                  "enum": ["owner", "admin", "member"]
                },
                "flair": { "$ref": "#/components/schemas/GroupFlair" }
              }
            }
          }
        }
      }
    }
  }
}
