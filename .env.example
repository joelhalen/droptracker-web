# =========================================================================
# DropTracker Web — environment variables
# Copy to `.env.local` (Next.js) and fill in. Never commit real secrets.
# See FRONTEND_PLAN.md §16 / §20.2.
# =========================================================================

# --- Shared with backend ------------------------------------------------
# Discord OAuth application credentials (already exist in backend .env).
DISCORD_BOT_CLIENT_ID=
DISCORD_BOT_CLIENT_SECRET=
# Callback now points at the BFF route handler, e.g.
#   http://localhost:3000/api/auth/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Session signing key (shared with backend; HS256 JWT).
JWT_TOKEN_KEY=

# --- Front-end (Next.js BFF) -------------------------------------------
# Public base for the Web API. With the BFF, the browser only talks to
# Next.js, so this is usually same-origin ("/api").
NEXT_PUBLIC_API_BASE=/api
# Server-side only: where the BFF reaches the Web API v1 process.
WEB_API_INTERNAL_URL=http://localhost:31325
# Secret used to sign/encrypt the session cookie issued by the BFF.
SESSION_COOKIE_SECRET=change-me-in-production-min-32-chars
# Whether session/OAuth cookies get the Secure flag. MUST stay false when the
# origin is plain HTTP (e.g. behind Cloudflare Flexible SSL) — browsers
# silently drop Secure cookies over HTTP and sign-in loops forever. Only set
# true with end-to-end TLS.
SESSION_COOKIE_SECURE=false
# Canonical site URL (used for OAuth redirects / absolute links).
NEXTAUTH_URL=http://localhost:3000

# When true, the BFF serves built-in mock data if the Web API is
# unreachable, so the UI is runnable before the backend exists.
USE_MOCK_API=true
